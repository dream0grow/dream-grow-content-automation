# --- Database ---
POSTGRES_USER=dreamgrow
POSTGRES_PASSWORD=dreamgrow
POSTGRES_DB=dreamgrow
DATABASE_URL=postgresql+asyncpg://dreamgrow:dreamgrow@localhost:5432/dreamgrow
DATABASE_SYNC_URL=postgresql+psycopg://dreamgrow:dreamgrow@localhost:5432/dreamgrow

# --- Redis / Celery ---
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# --- Security ---
# openssl rand -hex 32
JWT_SECRET=replace-me-with-strong-secret
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
KEY_VAULT_KEY=replace-with-fernet-key

# --- Admin bootstrap ---
ADMIN_EMAIL=admin@dreamgrow.local
ADMIN_PASSWORD=changeme
ADMIN_NAME=Dream Grow Admin

# --- LLM ---
ANTHROPIC_API_KEY=sk-ant-...
# Optional fallback to Claude CLI binary if no API key
CLAUDE_BIN=

# --- Threads (Meta) ---
THREADS_ACCESS_TOKEN=
THREADS_USER_ID=

# --- Maily ---
MAILY_ACCESS_TOKEN=

# --- Honcho (style memory, optional) ---
HONCHO_API_KEY=
HONCHO_APP_ID=dream-grow

# --- PDF rendering ---
PDF_OUTPUT_DIR=/data/pdfs
FONT_PATH=/usr/share/fonts/opentype/noto/NotoSansCJK-Regular.ttc

# --- App ---
APP_TIMEZONE=Asia/Seoul
APP_PUBLIC_URL=http://localhost:3000
APP_API_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:3000

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000
INTERNAL_API_URL=http://localhost:8000
