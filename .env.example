# Claude API (없으면 MOCK_LLM=true로 개발 가능)
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6
MOCK_LLM=false

# Meta Threads API (없으면 자동으로 dry-run 발행)
THREADS_ACCESS_TOKEN=
THREADS_USER_ID=
PUBLISH_DRY_RUN=true

# DB (기본 SQLite, Postgres 전환 시 URL 교체)
DATABASE_URL=sqlite:///./data/dreamgrow.db
# DATABASE_URL=postgresql+psycopg://dreamgrow:dreamgrow@localhost:5432/dreamgrow

# 예약 발행 스케줄러
SCHEDULER_ENABLED=true

# 개발용 CORS (Vite dev 서버)
CORS_ORIGINS=http://localhost:5173

TZ=Asia/Seoul
