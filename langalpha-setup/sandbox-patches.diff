index 8c552ce..53567a1 100644
--- a/src/agent/Dockerfile
+++ b/src/agent/Dockerfile
@@ -6,6 +6,15 @@ ENV PYTHONDONTWRITEBYTECODE=1 \
 
 WORKDIR /app
 
+COPY ca-certificates.crt /usr/local/share/ca-certificates/sandbox-proxy.crt
